# SmartGuard AI MVP local configuration

APP_NAME=SmartGuard AI MVP
APP_ENV=local
APP_VERSION=0.1.0

API_HOST=127.0.0.1
API_PORT=8000

SQLITE_DATABASE_URL=sqlite:///./smartguard.db

STORAGE_ROOT=../storage
EVENTS_STORAGE_DIR=../storage/events
CLIPS_STORAGE_DIR=../storage/clips
CONSENTS_STORAGE_DIR=../storage/consents
FACE_ENROLLMENT_STORAGE_DIR=../storage/face_enrollment
LOG_DIR=../storage/logs

# Reserved for later phases. Do not use in Phase 0.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Reserved for later privacy-safe face recognition phase.
FACE_MATCH_THRESHOLD=0.65
MIN_FACE_QUALITY=0.5
EVENT_COOLDOWN_SECONDS=60
