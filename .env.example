# SmartGuard AI MVP local configuration

APP_NAME=SmartGuard AI MVP
APP_ENV=local
APP_VERSION=0.1.0

API_HOST=127.0.0.1
API_PORT=8000

DATABASE_URL=sqlite:///./smartguard.db
SQLITE_DATABASE_URL=sqlite:///./smartguard.db

STORAGE_ROOT=../storage
EVENTS_STORAGE_DIR=../storage/events
CLIPS_STORAGE_DIR=../storage/clips
CONSENTS_STORAGE_DIR=../storage/consents
FACE_ENROLLMENT_STORAGE_DIR=../storage/face_enrollment
LOG_DIR=../storage/logs

# Stable Camera Source MVP: Hikvision ISAPI HTTP snapshot.
HIKVISION_HOST=192.168.0.102
HIKVISION_USER=admin
HIKVISION_PASSWORD=CHANGE_ME
HIKVISION_HTTP_PORT=80
HIKVISION_DEFAULT_CHANNEL=101
CAMERA_SOURCE_MODE=hikvision_isapi_snapshot

# Object Detection MVP.
DETECTION_ENABLED=true
# Options: ultralytics_yolo, onnxruntime, openvino, ncnn, camera_ai, disabled, mock
DETECTION_BACKEND=ultralytics_yolo
DETECTION_MODEL=yolo11n.pt
DETECTION_CONFIDENCE_THRESHOLD=0.45
DETECTION_ALLOWED_CLASSES=person,car,truck,motorcycle,bicycle
DETECTION_IMAGE_SIZE=640
DETECTION_SAVE_ANNOTATED=true
ONNX_MODEL_PATH=models/yolo11n.onnx
OPENVINO_MODEL_PATH=models/yolo11n_openvino_model
NCNN_MODEL_PATH=models/yolo11n_ncnn_model
CAMERA_AI_PROVIDER=hikvision
DETECTION_RUN_INTERVAL_SECONDS=1.0
DETECTION_MAX_FPS_PER_CAMERA=1
DETECTION_DEVICE=auto

# Camera MVP diagnostics.
# Hikvision/HiWatch main stream example:
# RTSP_URL=rtsp://username:password@192.168.0.102:554/Streaming/Channels/101
# Hikvision/HiWatch sub stream example:
# RTSP_URL=rtsp://username:password@192.168.0.102:554/Streaming/Channels/102
RTSP_URL=rtsp://username:password@192.168.0.102:554/Streaming/Channels/101
CAMERA_HOST=192.168.0.102
CAMERA_RTSP_PORT=554
CAMERA_TEST_MAX_FRAMES=30
CAMERA_TEST_READ_DELAY_SECONDS=0.2

# Telegram Alerts MVP.
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME
TELEGRAM_SEND_PHOTOS=true
TELEGRAM_ALERT_COOLDOWN_SECONDS=5

# Reserved for later privacy-safe face recognition phase.
FACE_MATCH_THRESHOLD=0.65
MIN_FACE_QUALITY=0.5

EVENT_ENABLED=true
EVENT_COOLDOWN_SECONDS=60

# Live Vision Tracking MVP.
TRACKING_ENABLED=true
TRACK_TTL_SECONDS=10
TRACK_MAX_PATH_POINTS=30
TRACK_IOU_THRESHOLD=0.3
TRACK_DISTANCE_THRESHOLD=120
VISION_WORKER_ENABLED=false
VISION_WORKER_INTERVAL_SECONDS=1.0
VISION_WORKER_CHANNELS=101
DWELL_ENABLED=true
LOITERING_THRESHOLD_SECONDS=30
